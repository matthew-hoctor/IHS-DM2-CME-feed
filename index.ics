BEGIN:VCALENDAR
VERSION:2.0
PRODID:-//IHS Diabetes Calendar//github.com//
CALSCALE:GREGORIAN
METHOD:PUBLISH
X-WR-CALDESC:Calendar of IHS Diabetes training webinars
X-WR-CALNAME:IHS Advancements in Diabetes Training
BEGIN:VTIMEZONE
TZID:Eastern Time
BEGIN:STANDARD
DTSTART:20061101T020000
RRULE:FREQ=YEARLY;INTERVAL=1;BYDAY=1SU;BYMONTH=11
TZNAME:Standard Time
TZOFFSETFROM:-0400
TZOFFSETTO:-0500
END:STANDARD
BEGIN:DAYLIGHT
DTSTART:20060301T020000
RRULE:FREQ=YEARLY;INTERVAL=1;BYDAY=2SU;BYMONTH=3
TZNAME:Daylight Savings Time
TZOFFSETFROM:-0500
TZOFFSETTO:-0400
END:DAYLIGHT
END:VTIMEZONE
END:VCALENDAR
